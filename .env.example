# ============================================================================
# Environment variables for swin_fire reproducibility experiments
# ============================================================================
# Copy this file to .env and fill in your paths:
#   cp .env.example .env
#   source .env
# ============================================================================

# Root directory containing dataset_train/ and dataset_val/ subdirectories
export TS_SATFIRE_DATA_ROOT="/home/congwei/swin_fire_new/data/processed"

# Swin-Tiny pretrained weights (from timm or Swin official)
# Local copy in the project directory:
export SWIN_PRETRAINED_PATH="/home/congwei/swin_fire_new/swin_pretrained/swin_tiny_patch4_window7_224.pth"

# Sample manifest CSV with aggregate train/val info
export SAMPLE_MANIFEST="/home/congwei/swin_fire_new/data/processed/dataset_train/sample_manifest.csv"

# W&B entity (optional - uses authenticated account default if unset)
# export WANDB_ENTITY=""
